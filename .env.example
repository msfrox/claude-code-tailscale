# Copy to .env and fill in. Used by docker compose.

# Hostname this node advertises on your tailnet.
TS_HOSTNAME=claude-code

# Optional: Tailscale auth key for an unattended first join.
# Generate at: Tailscale admin console -> Settings -> Keys -> Generate auth key.
# Leave blank to authenticate interactively via the login URL printed in logs.
# After the first successful join this is no longer needed (state is persisted).
TS_AUTHKEY=

# Where projects are stored on the host (bind-mounted to /workspace in the
# container). Defaults to ./projects next to the compose file. Point this at a
# NAS/array path to keep projects on persistent storage, e.g.:
#   WORKSPACE_PATH=/mnt/your/nas/path/Projects
WORKSPACE_PATH=./projects
